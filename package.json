{
  "name": "corner-cut-reversi-eval",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "異形オセロ(通常/クロス/八角/ホローの4盤面)の検討盤・評価値計算アプリ",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "check:engine": "esbuild scripts/engine-check.ts --bundle --platform=node --format=esm --outfile=scripts/.engine-check.mjs && node scripts/.engine-check.mjs"
  },
  "devDependencies": {
    "typescript": "^5.4.5",
    "vite": "^5.2.11"
  }
}
